# =============================================================================
# RUT Portal - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
**/node_modules/

# -----------------------------------------------------------------------------
# Environment files (NEVER commit these)
# -----------------------------------------------------------------------------
.env
.env.local
.env.production
.env.staging
**/.env
**/.env.local

# -----------------------------------------------------------------------------
# Build output
# -----------------------------------------------------------------------------
dist/
build/
**/dist/
**/build/
.vite/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Uploaded files
# -----------------------------------------------------------------------------
uploads/
**/uploads/

# -----------------------------------------------------------------------------
# OS generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# IDE and editor files
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.history/

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
**/coverage/

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
*.tmp
*.temp
.cache/
**/.cache/

# -----------------------------------------------------------------------------
# Package manager lock files (keep one, ignore others)
# Uncomment the ones you do NOT use
# -----------------------------------------------------------------------------
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# -----------------------------------------------------------------------------
# Sequelize
# -----------------------------------------------------------------------------
# Uncomment if you want to ignore migration history
# .sequelizerc

# -----------------------------------------------------------------------------
# SSL certificates (never commit these)
# -----------------------------------------------------------------------------
*.pem
*.key
*.crt
*.cert

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.dockerignore

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.pid
*.seed
*.pid.lock
.npm
.eslintcache
.stylelintcache
