# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rut_portal
DB_USER=postgres
DB_PASSWORD=password

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here_minimum_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_key_here_minimum_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── File Upload ──────────────────────────────────────────────────────────────
UPLOAD_PATH=src/uploads
MAX_FILE_SIZE=10485760

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs
